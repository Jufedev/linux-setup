[Appearance]
ColorScheme=MacOS
Font=JetBrains Mono,12,-1,5,400,0,0,0,0,0
UseFontLineChararacters=false

[General]
Command=/bin/bash
Name=MacOS
Parent=FALLBACK/
TerminalColumns=120
TerminalRows=30

[Interaction Options]
CopyTextAsHTML=false
TrimLeadingWhitespacesInSelectedText=true
TrimTrailingWhitespacesInSelectedText=true
UnderlineFilesEnabled=true

[Scrolling]
HistoryMode=2
ScrollBarPosition=2

[Terminal Features]
BellMode=0
BlinkingCursorEnabled=true
UrlHintsModifiers=0
